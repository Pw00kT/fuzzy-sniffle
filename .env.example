# Anthropic Claude API (required for AI features)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI Whisper API (required for audio transcription)
OPENAI_API_KEY=sk-...

# PostgreSQL connection string (optional - falls back to in-memory storage)
DATABASE_URL=postgresql://user:password@localhost:5432/idot_meetings

# Server port (default: 3001)
PORT=3001

# Upload directory for audio files (default: ./uploads)
UPLOAD_DIR=./uploads

# Access token for simple auth (optional - leave unset to disable auth entirely)
# Set to any secret string; users must enter this on the login page.
AUTH_TOKEN=your-secret-token-here
